#include<stdio.h>

int cari(int arr[1000]) {

    for(int i = 0; i < 1000; i++) {
        if(arr[i] == 69) {
            return i;
        }
    }
    return -1;
}

int main() {
    int data[1000];

    // mengisi array
    for(int i = 0; i < 1000; i++) {
        data[i] = i;
    }

    int hasil = cari(data);

    if(hasil != -1)
        printf("Nilai 69 ditemukan di index %d\n", hasil);
    else
        printf("Nilai tidak ditemukan\n");

    return 0;
}

